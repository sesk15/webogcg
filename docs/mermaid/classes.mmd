        +String surname
        +String dni
        +String email
        +Boolean isActive
        +Boolean isMaster
    }

    class Estructura {
        +Int id
        +Int userId
        +Int papelId
        +Int agrupacionId
        +Int seccionId
        +Boolean activo
        +Int atril
    }

    class Residencia {
        +Int id
        +String isla
        +String municipio
    }

    class Empleo {
        +Int id
        +String trabajo
        +String estudios
    }

    class Score {
        +Int id
        +String title
        +String fileUrl
        +String[] allowedAgrupaciones
        +String[] allowedRoles
    }

    class Category {
        +Int id
        +String name
