    }

    class Event {
        +Int id
        +String title
        +DateTime date
        +EventType type
    }

    class JoinRequest {
        +Int id
        +String name
        +String email
        +String status
    }

    class ActivityLog {
        +Int id
        +String action
        +Json details
    }

